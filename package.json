{
  "name": "easymint",
  "version": "0.3.3",
  "description": "AI 项目工作台 — 通过 Claude Agent SDK 驱动的智能编程助手，让不懂技术的人也能构建软件",
  "private": true,
  "license": "AGPL-3.0",
  "main": "app/main/dist/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite --config app/renderer/vite.config.ts",
    "dev:electron": "npm run build:main && npm run build:preload && electron .",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload && electron-builder",
    "build:ci": "npm run build:renderer && npm run build:main && npm run build:preload && electron-builder --publish never",
    "build:renderer": "vite build --config app/renderer/vite.config.ts",
    "build:main": "esbuild app/main/index.ts --bundle --platform=node --format=cjs --outfile=app/main/dist/main.cjs --external:electron --external:@anthropic-ai/claude-agent-sdk",
    "build:preload": "esbuild app/preload/index.ts --bundle --platform=node --format=cjs --outfile=app/preload/dist/preload.cjs --external:electron",
    "lint": "eslint app/ && tsc --noEmit -p app/main/tsconfig.json && tsc --noEmit -p app/preload/tsconfig.json && tsc --noEmit -p app/renderer/tsconfig.json",
    "typecheck": "tsc --noEmit -p app/main/tsconfig.json && tsc --noEmit -p app/preload/tsconfig.json && tsc --noEmit -p app/renderer/tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.186",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "electron-updater": "^6.8.9",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.14"
  },
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk-darwin-arm64": "0.3.186",
    "@anthropic-ai/claude-agent-sdk-darwin-x64": "0.3.186",
    "@anthropic-ai/claude-agent-sdk-win32-arm64": "0.3.186",
    "@anthropic-ai/claude-agent-sdk-win32-x64": "0.3.186"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "com.easymint.app",
    "productName": "EasyMint",
    "icon": "assets/icon.icns",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "app/main/dist/**/*",
      "app/preload/dist/**/*",
      "app/renderer/dist/**/*",
      "assets/icon.icns",
      "assets/icon.ico",
      "assets/icon.png",
      "package.json",
      "node_modules/@anthropic-ai/**/*"
    ],
    "asarUnpack": [
      "node_modules/@anthropic-ai/**"
    ],
    "publish": {
      "provider": "github"
    },
    "extraResources": [
      {
        "from": "template",
        "to": "template"
      },
      {
        "from": "resources/skills",
        "to": "skills"
      }
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "artifactName": "${productName}-macOS-${arch}.${ext}",
      "notarize": false
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": true,
      "artifactName": "${productName}-windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "include": "scripts/installer.nsh"
    },
    "portable": {
      "artifactName": "${productName}-windows-${arch}-portable.${ext}"
    }
  }
}
