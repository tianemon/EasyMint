{
  "name": "image-vision",
  "version": "0.1.0",
  "description": "为 DeepSeek 等纯文本模型补齐视觉能力，支持图片描述和 UI 验证",
  "author": {
    "name": "amon"
  },
  "userConfig": {
    "VISION_API_KEY": {
      "type": "string",
      "title": "视觉模型 API Key",
      "description": "DashScope / OpenAI 等兼容视觉模型的 API Key",
      "required": true,
      "sensitive": true
    },
    "VISION_BASE_URL": {
      "type": "string",
      "title": "API 地址",
      "description": "OpenAI 兼容的接口地址",
      "default": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "required": false
    },
    "VISION_MODEL": {
      "type": "string",
      "title": "模型名称",
      "description": "视觉模型名",
      "default": "qwen3.6-flash",
      "required": false
    }
  }
}
